# ============================================================
# Azure LLM 設定樣板（可 commit；本檔不放真值，只示範格式）
#
# 給 Wes 的填寫指引 —— 每個欄位前都標了分類：
#   🟢 必須完整給我  ：非機密，且我需要「精確值」才能寫對程式，請照真值填。
#   🔴 絕對不要給我  ：機密，請維持 xxxx，真值只放在 backend/.env。
#   🟡 給我但要調整  ：半敏感，遮掉機密部分、但保留結構（怎麼遮見各欄說明）。
#
# 使用方式：你把這個檔填好（遵守上面分類）後貼給我看，我就能補完認證細節。
# 真值請放在 backend/.env（已被 .gitignore 排除）。
# ============================================================

# 🟢 必須完整給我：是否啟用 Azure 模型（true / false），非機密。
AZURE_LLM_ENABLED=true

# base endpoint（不含 /openai/... 或 /anthropic/... 路徑）。
#    保留網域後綴（例如 .cognitiveservices.azure.com，決定 gateway 類型），
#    資源名稱請遮成 xxxx；真值只放在 backend/.env。
AZURE_LLM_ENDPOINT=https://xxxx.cognitiveservices.azure.com

# 🔴 絕對不要給我：API 金鑰。這個檔請永遠維持 xxxx，真值只放 backend/.env。
AZURE_LLM_API_KEY=xxxx

# 🟢 必須完整給我：api-version（非機密，但我要精確值才能組對 URL）。
#    照真值填，例如：2025-04-01-preview
AZURE_LLM_API_VERSION=2025-04-01-preview

# ------------------------------------------------------------
# 🟢 必須完整給我（三個模型）：非機密，格式為三或四欄，用 | 分隔：
#       顯示名稱 | protocol | deployment或model-id | [vision|novision]
#
#   protocol 只能填：
#     openai     → 走 {ENDPOINT}/openai/deployments/{第三欄}/chat/completions?api-version=...
#     anthropic  → 走 {ENDPOINT}/anthropic/v1/messages（第三欄為 model id）
#
#   第 4 欄（可選）：是否支援讀圖（多模態），預設視為支援。
#     - 不支援讀圖的模型請標 novision（整理頁附圖時會自動退回只用文字描述）
#     - 例：Kimi-K2.5|openai|Kimi-K2.5|novision
#
#   ⚠️ 你目前在 .env 只填了單一名稱（例如 gpt-5.4），缺了 protocol 和 deployment。
#      請改成完整三欄。範例：
#         gpt-5.4|openai|gpt-5.4
#         Kimi-K2.5|openai|Kimi-K2.5
#         claude-opus|anthropic|claude-opus-4-6-2026V2
#      （第一欄是前端下拉要顯示的名字，可自取；第三欄是 Azure 實際的 deployment / model id）
#
#   不確定某個模型走哪種 protocol？把該模型官方的呼叫範例（URL + header，金鑰遮掉）貼給我，我幫你判斷。
# ------------------------------------------------------------
AZURE_LLM_MODEL_1=gpt-5.4|openai|gpt-5.4
AZURE_LLM_MODEL_2=Kimi-K2.5|openai|Kimi-K2.5|novision
AZURE_LLM_MODEL_3=claude-opus|anthropic|claude-opus-4-6-2026V2

# ------------------------------------------------------------
# （可選）Issue 整理頁的留言圖片處理
# ------------------------------------------------------------
# 單一 issue 最多處理幾張留言圖片（預設 6）
# ARRANGE_IMAGE_MAX_COUNT=6
# 單張圖片大小上限（位元組，預設 4MB）
# ARRANGE_IMAGE_MAX_BYTES=4194304
# Scrape 階段「圖片轉描述」要用的視覺模型（留空則自動從可用模型挑）
# ARRANGE_VISION_MODEL=gemini-2.5-pro
