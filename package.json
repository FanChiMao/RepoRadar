{
  "name": "gitlab-tracker",
  "version": "1.2.4",
  "description": "GitLab and GitHub issue tracking, AI analysis, and reporting.",
  "main": "dist/src/main.js",
  "author": "OpenAI",
  "license": "MIT",
  "scripts": {
    "build:ts": "tsc -p tsconfig.json",
    "dev": "npm run build:ts && electron .",
    "format": "prettier --write \"*.{json,md}\" \"src/**/*.ts\" \"frontend/**/*.{ts,html,css}\" && .venv\\Scripts\\python -m black backend",
    "format:check": "prettier --check \"*.{json,md}\" \"src/**/*.ts\" \"frontend/**/*.{ts,html,css}\" && .venv\\Scripts\\python -m black --check backend",
    "pack:backend": "python -m PyInstaller --noconfirm --onedir --name gitlab-tracker-backend --hidden-import uvicorn.logging --hidden-import uvicorn.lifespan --hidden-import uvicorn.lifespan.on --hidden-import uvicorn.protocols --hidden-import uvicorn.protocols.http --hidden-import uvicorn.protocols.http.auto --hidden-import uvicorn.protocols.http.h11_impl --hidden-import uvicorn.protocols.http.httptools_impl --hidden-import uvicorn.protocols.websockets --hidden-import uvicorn.protocols.websockets.auto --hidden-import uvicorn.protocols.websockets.wsproto_impl --hidden-import uvicorn.loops --hidden-import uvicorn.loops.auto --hidden-import uvicorn.loops.asyncio backend/app.py --distpath backend/dist --workpath backend/build --specpath backend",
    "pack": "npm run build:ts && npm run pack:backend && electron-builder --dir",
    "dist": "npm run build:ts && npm run pack:backend && electron-builder"
  },
  "devDependencies": {
    "electron": "^41.2.2",
    "electron-builder": "^26.8.1",
    "png2icons": "^2.0.1",
    "prettier": "^3.8.3",
    "typescript": "^5.8.3"
  },
  "build": {
    "appId": "com.openai.gitlabtracker",
    "productName": "Gitlab Tracker",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "frontend/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend/dist",
        "to": "backend/dist",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "icon": "assets/icon.ico",
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "deleteAppDataOnUninstall": true
    },
    "publish": {
      "provider": "github",
      "owner": "FanChiMao",
      "repo": "GitlabTracker"
    }
  },
  "dependencies": {
    "boolean": "^3.2.0",
    "buffer-crc32": "^0.2.13",
    "cacheable-lookup": "^5.0.4",
    "cacheable-request": "^7.0.4",
    "clone-response": "^1.0.3",
    "debug": "^4.4.3",
    "decompress-response": "^6.0.0",
    "defer-to-connect": "^2.0.1",
    "define-data-property": "^1.1.4",
    "define-properties": "^1.2.1",
    "detect-node": "^2.1.0",
    "end-of-stream": "^1.4.5",
    "env-paths": "^2.2.1",
    "es-define-property": "^1.0.1",
    "es-errors": "^1.3.0",
    "es6-error": "^4.1.1",
    "escape-string-regexp": "^4.0.0",
    "extract-zip": "^2.0.1",
    "fd-slicer": "^1.1.0",
    "fs-extra": "^8.1.0",
    "get-stream": "^5.2.0",
    "global-agent": "^3.0.0",
    "globalthis": "^1.0.4",
    "gopd": "^1.2.0",
    "got": "^11.8.6",
    "graceful-fs": "^4.2.11",
    "has-property-descriptors": "^1.0.2",
    "http-cache-semantics": "^4.2.0",
    "http2-wrapper": "^1.0.3",
    "json-buffer": "^3.0.1",
    "json-stringify-safe": "^5.0.1",
    "jsonfile": "^4.0.0",
    "keyv": "^4.5.4",
    "lowercase-keys": "^2.0.0",
    "matcher": "^3.0.0",
    "mimic-response": "^1.0.1",
    "ms": "^2.1.3",
    "normalize-url": "^6.1.0",
    "object-keys": "^1.1.1",
    "once": "^1.4.0",
    "p-cancelable": "^2.1.1",
    "pend": "^1.2.0",
    "progress": "^2.0.3",
    "pump": "^3.0.4",
    "quick-lru": "^5.1.1",
    "resolve-alpn": "^1.2.1",
    "responselike": "^2.0.1",
    "roarr": "^2.15.4",
    "semver": "^6.3.1",
    "semver-compare": "^1.0.0",
    "serialize-error": "^7.0.1",
    "sprintf-js": "^1.1.3",
    "sumchecker": "^3.0.1",
    "type-fest": "^0.13.1",
    "undici-types": "^7.16.0",
    "universalify": "^0.1.2",
    "wrappy": "^1.0.2",
    "yauzl": "^2.10.0"
  }
}
